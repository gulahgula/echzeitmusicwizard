{
  "manifest_version": 3,
  "name": "echtzeitmusik Berlin",
  "version": "2.2.0",
  "description": "Berlin experimental music calendar watcher — explore concerts from echtzeitmusik.de, follow artists, get notified before shows, and build your artist catalogue.",
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://echtzeitmusik.de/*",
    "https://gulahgula.github.io/*",
    "https://bandcamp.com/*",
    "https://*.bandcamp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "echtzeitmusik",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "homepage_url": "https://github.com/gulahgula/echzeitmusicwizard",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
